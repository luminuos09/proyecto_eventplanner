<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="presentacion.controllers.MenuParticipantesController"
            prefHeight="700.0" prefWidth="1000.0" styleClass="root" stylesheets="@../styles.css">
    
    <!-- ENCABEZADO -->
    <top>
        <VBox styleClass="header" alignment="CENTER" spacing="10">
            <padding>
                <Insets top="30" bottom="30" left="20" right="20"/>
            </padding>
            
            <Label text="👥 GESTIÓN DE PARTICIPANTES" styleClass="title">
                <font>
                    <Font name="Poppins Bold" size="48"/>
                </font>
            </Label>
            
            <Label text="Registra, inscribe y administra participantes" styleClass="subtitle">
                <font>
                    <Font name="Poppins" size="18"/>
                </font>
            </Label>
        </VBox>
    </top>
    
    <!-- CONTENIDO CENTRAL -->
    <center>
        <VBox alignment="CENTER" spacing="30">
            <padding>
                <Insets top="50" bottom="50" left="50" right="50"/>
            </padding>
            
            <!-- Grid de botones -->
            <GridPane hgap="30" vgap="30" alignment="CENTER">
                
                <!-- Fila 1 -->
                <Button text="➕ REGISTRAR PARTICIPANTE" styleClass="btn-menu" 
                        onAction="#abrirFormularioParticipante"
                        GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <font>
                        <Font name="Poppins SemiBold" size="16"/>
                    </font>
                </Button>
                
                <Button text="📋 LISTAR PARTICIPANTES" styleClass="btn-menu"
                        onAction="#listarParticipantes"
                        GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <font>
                        <Font name="Poppins SemiBold" size="16"/>
                    </font>
                </Button>
                
                <!-- Fila 2 -->
                <Button text="🎟️ INSCRIBIR A EVENTO" styleClass="btn-menu"
                        onAction="#abrirInscripcionEvento"
                        GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <font>
                        <Font name="Poppins SemiBold" size="16"/>
                    </font>
                </Button>
                
                <Button text="❌ CANCELAR INSCRIPCIÓN" styleClass="btn-menu"
                        onAction="#cancelarInscripcion"
                        GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <font>
                        <Font name="Poppins SemiBold" size="16"/>
                    </font>
                </Button>
                
                <!-- Fila 3 -->
                <Button text="📅 VER MIS EVENTOS" styleClass="btn-menu"
                        onAction="#verMisEventos"
                        GridPane.columnIndex="0" GridPane.rowIndex="2">
                    <font>
                        <Font name="Poppins SemiBold" size="16"/>
                    </font>
                </Button>
                
                <Button text="🔍 BUSCAR PARTICIPANTE" styleClass="btn-menu"
                        onAction="#buscarParticipante"
                        GridPane.columnIndex="1" GridPane.rowIndex="2">
                    <font>
                        <Font name="Poppins SemiBold" size="16"/>
                    </font>
                </Button>
            </GridPane>
            
            <!-- Botón volver -->
            <Button text="⬅️ VOLVER AL MENÚ PRINCIPAL" styleClass="btn-salir"
                    onAction="#volverMenuPrincipal">
                <font>
                    <Font name="Poppins" size="14"/>
                </font>
            </Button>
        </VBox>
    </center>
    
    <!-- PIE DE PÁGINA -->
    <bottom>
        <HBox styleClass="footer" alignment="CENTER">
            <padding>
                <Insets top="15" bottom="15"/>
            </padding>
            <Label text="Event Planner © 2025 - Sistema de Gestión de Eventos" styleClass="footer-text">
                <font>
                    <Font name="Poppins" size="12"/>
                </font>
            </Label>
        </HBox>
    </bottom>
    
</BorderPane>